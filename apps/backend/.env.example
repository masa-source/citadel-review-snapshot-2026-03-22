# .env ファイル
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres # Docker Compose のデフォルト値と同じ
POSTGRES_DB=report_binder
SQL_ECHO=true # 開発中は true にするとSQLログが見れて便利です

# Sentry エラー監視
# SENTRY_DSN_BACKEND=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=development

# APIキー認証
# REQUIRE_API_KEY=true # 本番環境では true に設定
# API_KEY_SCOUT=your-scout-api-key-here
# API_KEY_ADMIN=your-admin-api-key-here

# AI抽出（LM Studio / vLLM 等・OpenAI互換API）
AI_API_BASE_URL=http://localhost:1234/v1
# LM Studio のモデルIDは GET http://localhost:1234/v1/models で確認し、data[].id と一致させる
AI_MODEL_NAME=qwen/qwen3.5-9b
AI_API_KEY=sk-local