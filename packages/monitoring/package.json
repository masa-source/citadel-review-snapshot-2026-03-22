{
  "name": "@citadel/monitoring",
  "version": "1.0.0",
  "private": true,
  "description": "Citadel エラーレポート・Sentry 共通ユーティリティ",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "lint": "echo 'No lint for monitoring package'"
  },
  "peerDependencies": {
    "@sentry/react": ">=10"
  },
  "devDependencies": {
    "@citadel/typescript-config": "workspace:*",
    "@sentry/react": "^10.40.0",
    "@types/node": "^22.0.0",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
