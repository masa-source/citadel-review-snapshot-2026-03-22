# =============================================================================
# Citadel 環境設定ファイル（例）
# =============================================================================
# このファイルをコピーして .env を作成してください：
#   copy .env.example .env
#
# .env ファイルは gitignore されており、AIエージェントからも見えません。
# =============================================================================

# -----------------------------------------------------------------------------
# Sentry エラー監視設定
# -----------------------------------------------------------------------------
# Sentry プロジェクトの DSN（Data Source Name）
# https://sentry.io で取得できます
# 各アプリ用の DSN を設定してください

# Scout (現場アプリ) 用 DSN
VITE_SENTRY_DSN_SCOUT=

# Admin (管理画面) 用 DSN
VITE_SENTRY_DSN_ADMIN=

# Backend (FastAPI) 用 DSN
SENTRY_DSN_BACKEND=

# Sentry 環境名（development / production）
SENTRY_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# APIキー認証設定
# -----------------------------------------------------------------------------
# 開発時は REQUIRE_API_KEY=false（デフォルト）で認証なしで動作
# 本番環境では true に設定してください

# APIキー認証を必須にするか（true/false）
REQUIRE_API_KEY=false

# Scout (現場アプリ) 用 APIキー
# 32文字以上のランダムな文字列を推奨
# 例: openssl rand -hex 32 で生成
API_KEY_SCOUT=

# Admin (管理画面) 用 APIキー
API_KEY_ADMIN=

# フロントエンドから使用するAPIキー（VITE_ プレフィックス必須）
# 上記と同じ値を設定してください
VITE_API_KEY_SCOUT=
VITE_API_KEY_ADMIN=

# -----------------------------------------------------------------------------
# データベース設定
# -----------------------------------------------------------------------------
# PostgreSQL 接続URL
# 本番環境では別のデータベース名を使用することを推奨
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/report_binder

# Docker Compose 用（docker-compose.yml で使用）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=report_binder

# SQLデバッグログ出力（1=有効, 0=無効）
SQL_ECHO=0

# -----------------------------------------------------------------------------
# テンプレート設定
# -----------------------------------------------------------------------------
# カスタムテンプレートディレクトリ（未設定時は assets/template を使用）
# 本番用テンプレートを使う場合: TEMPLATE_DIR=template-local
# TEMPLATE_DIR=template-local

# -----------------------------------------------------------------------------
# CORS 設定
# -----------------------------------------------------------------------------
# 許可するオリジン（カンマ区切り）。未設定時は http://localhost:3000,http://localhost:3001
# "*" を指定した場合も credentials のため上記に展開されます。
#
# 【重要】Citadel から Scout を起動したあと「データの読み込みに失敗」する場合:
# ブラウザは Scout のオリジン（例: http://192.168.1.100:3000）でバックエンドにリクエストを送ります。
# デフォルトは localhost のみ許可しているため、IP や他PCで開いた Scout は CORS でブロックされます。
# 対処: バックエンドの ALLOWED_ORIGINS に Scout/Admin の実際のオリジンを追加し、再起動してください。
#
# 例（サーバIPが 192.168.1.100 のとき）:
#   ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://192.168.1.100:3000,http://192.168.1.100:3001
# 本番では実ドメインを指定: ALLOWED_ORIGINS=https://admin.example.com,https://scout.example.com
#
# 詳細: docs/HANDOFF_TROUBLESHOOTING.md

# -----------------------------------------------------------------------------
# フロントエンドから参照するURL（未設定時は表示中のホストを使用）
# -----------------------------------------------------------------------------
# Admin/Scout が API や Scout 起動先を決める際に使用。未設定なら「今開いているホスト:8000 / :3000」を参照。
# 他PCから開く場合は未設定のままでよい（同じサーバのAPI・Scoutに届く）。
# VITE_API_URL=
VITE_SCOUT_URL=

# -----------------------------------------------------------------------------
# 本番環境用の設定例
# -----------------------------------------------------------------------------
# 以下のようにコメントを外して本番用に変更してください：
#
# DATABASE_URL=postgresql://postgres:<YOUR_STRONG_PASSWORD>@localhost:5432/<YOUR_DB_NAME>
# POSTGRES_PASSWORD=<YOUR_STRONG_PASSWORD>
# POSTGRES_DB=<YOUR_DB_NAME>
# TEMPLATE_DIR=template-local
# ALLOWED_ORIGINS=https://admin.example.com,https://scout.example.com
